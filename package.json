    },
    "homepage": "https://github.com/nontouch-dev/PHP-Learning#readme",
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.4",
        "browser-sync": "^3.0.4",
        "concurrently": "^9.2.1",
        "tailwindcss": "^4.2.4"
    }
}
